<?xml version="1.0" encoding="UTF-8"?>
<addons>
  <addon id="repository.jaguar" name="Jaguar Repository" version="1.0.0" provider-name="ashcan57">
    <extension point="xbmc.addon.repository" name="Jaguar Repository">
      <dir>
        <info compressed="false">https://raw.githubusercontent.com/ashcan57/jaguar/main/repo/zips/addons.xml</info>
        <checksum>https://raw.githubusercontent.com/ashcan57/jaguar/main/repo/zips/addons.xml.md5</checksum>
        <datadir zip="true">https://raw.githubusercontent.com/ashcan57/jaguar/main/repo/zips/</datadir>
      </dir>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary lang="en">Jaguar Repository</summary>
      <description lang="en">Jaguar Repository for family and friends.</description>
      <platform>all</platform>
    </extension>
  </addon>
  <addon id="plugin.program.jaguar.wizard" name="Jaguar Wizard" version="1.0.0" provider-name="ashcan57">
    <requires>
      <import addon="xbmc.python" version="3.0.0"/>
    </requires>
    <extension point="xbmc.python.pluginsource" library="default.py">
      <provides>executable</provides>
    </extension>
    <extension point="xbmc.addon.metadata">
      <summary lang="en">Jaguar Wizard</summary>
      <description lang="en">Install the Encore Kodi build from Jaguar.</description>
      <platform>all</platform>
    </extension>
  </addon>
</addons>
